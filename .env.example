# App
NODE_ENV=development
APP_NAME=ShortZlinks
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

# Database
MONGODB_URI=
MONGODB_DB_NAME=shortzlinks

# Redis
REDIS_URL=

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
SESSION_MAX_AGE_HOURS=6
ACCESS_TOKEN_MINUTES=15


# Mail
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Brevo fallback
BREVO_API_KEY=

# Telegram Bot
BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Public API
API_KEY_PREFIX=sk_live_
API_RATE_LIMIT_PER_MIN=60

# Payout
MIN_WITHDRAW_AMOUNT=200
WITHDRAW_OPEN_DAY=24
WITHDRAW_CLOSE_DAY=30

# Security
PROXY_CHECK_ENABLED=true
CLICK_LIMIT_HOURS=24
CLICK_LIMIT_PER_IP=1
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Ad Engine
DEFAULT_ROUTE_STEPS=2
DEFAULT_STEP1_TIMER=15
DEFAULT_STEP2_TIMER=10
DEFAULT_STEP3_TIMER=10
ADBLOCK_PROTECTION=true

# Domain
PRIMARY_SHORT_DOMAIN=
FALLBACK_SHORT_DOMAINS=

# Storage
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=